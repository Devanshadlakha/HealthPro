SERVER_PORT=8081

MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/doctorapp?retryWrites=true&w=majority

JWT_SECRET=change-me-to-a-64+-char-random-hex-secret

MAIL_HOST=sandbox.smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=
MAIL_PASSWORD=

FRONTEND_URL=http://localhost:3001
CORS_ALLOWED_ORIGINS=http://localhost:3001

# Set COOKIE_SECURE=true in production (requires HTTPS).
# When true, the JWT cookie is issued with Secure + SameSite=None so it works
# from a different-origin frontend (Vercel, etc.). Leave false for local http dev.
COOKIE_SECURE=false

RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxx
# Only needed if you configure webhooks in the Razorpay dashboard
RAZORPAY_WEBHOOK_SECRET=

CHATBOT_API_KEY=

UPLOAD_DIR=uploads

# Seed admin token — set to enable POST /seed/** with X-Seed-Token header. Leave blank in production.
SEED_TOKEN=

# Optional auth rate-limit overrides (defaults: 5 attempts / 60s)
AUTH_MAX_ATTEMPTS=5
AUTH_WINDOW_SECONDS=60

# Optional JWT lifetime override (default 24h = 86400000 ms)
JWT_EXPIRATION_MS=86400000
